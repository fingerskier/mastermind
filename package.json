{
  "name": "landsraad",
  "version": "2026.5.30",
  "description": "Local-first AI council chamber: create councils and councillors from a SvelteKit app.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "landsraad": "./bin/landsraad.js"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run build:cli",
    "build:cli": "node scripts/build-cli.mjs",
    "preview": "vite preview",
    "start": "node build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "predeploy": "npm run check && npm run test && npm run build",
    "prepublishOnly": "npm run check && npm run test && npm run build",
    "dogfood:init": "vite-node scripts/template-install.ts -- templates/dogfood.template.json --target ./dogfood --yes",
    "template:install": "vite-node scripts/template-install.ts --",
    "template:export": "vite-node scripts/template-export.ts --",
    "reset": "vite-node scripts/reset.ts --",
    "reindex": "vite-node scripts/reindex.ts"
  },
  "files": [
    "bin",
    "build",
    "example",
    "templates"
  ],
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.0",
    "croner": "^10.0.1",
    "marked": "^18.0.4",
    "sqlite-vec": "^0.1.9"
  }
}
